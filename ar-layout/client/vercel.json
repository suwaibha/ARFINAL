{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|ico|json|map|webmanifest))$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
